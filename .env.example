# Supabase - Empresas (cada empresa = banco de dados próprio)
# Empresa 1: FRANCA CRED (NEXUS)
VITE_SUPABASE_URL_EMPRESA1=https://seu-projeto.supabase.co
VITE_SUPABASE_ANON_KEY_EMPRESA1=sua-chave-anon

# Empresa 2: LITORAL CRED
VITE_SUPABASE_URL_EMPRESA2=
VITE_SUPABASE_ANON_KEY_EMPRESA2=

# Empresa 3: MOGIANA CRED
VITE_SUPABASE_URL_EMPRESA3=
VITE_SUPABASE_ANON_KEY_EMPRESA3=

# Empresa 4: IMPERATRIZ CRED
VITE_SUPABASE_URL_EMPRESA4=
VITE_SUPABASE_ANON_KEY_EMPRESA4=

# Evolution API (WhatsApp)
# URL fixa no código: https://sapphiredev.com.br

# Identidade visual dos PDFs (nome, filial, foro opcional)
VITE_COMPANY_NAME=Nexus Fintech
VITE_COMPANY_BRANCH=Franca
# VITE_COMPANY_FORO=Comarca de Franca/SP  # Opcional; usa padrão por filial se não definido

# ---------------------------------------------------------------------------
# Gestão de Tráfego (Supabase externos)
# ---------------------------------------------------------------------------
VITE_SUPABASE_URL_NOVIXCRED=
VITE_SUPABASE_ANON_KEY_NOVIXCRED=
VITE_SUPABASE_URL_CREDCARD=
VITE_SUPABASE_ANON_KEY_CREDCARD=

# ---------------------------------------------------------------------------
# Meta Dataset Quality (Graph API) - opcional
# ---------------------------------------------------------------------------
VITE_META_DATASET_ID=
VITE_META_DATASET_QUALITY_TOKEN=
# Padrão: v20.0
VITE_META_GRAPH_VERSION=v20.0
# Campos padrão: web{event_match_quality,event_name}
VITE_META_DATASET_QUALITY_FIELDS=web{event_match_quality,event_name}
# Opcional (recomendado em alguns cenários): nome do agente/parceiro
VITE_META_DATASET_QUALITY_AGENT_NAME=

# ---------------------------------------------------------------------------
# Análise documental do Atendimento
# ---------------------------------------------------------------------------
# Endpoint OpenAI-compatible para resumir documentos após OCR
DOCUMENT_ANALYSIS_BASE_URL=
DOCUMENT_ANALYSIS_API_KEY=
DOCUMENT_ANALYSIS_MODEL=

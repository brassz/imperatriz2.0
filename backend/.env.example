# Server
PORT=4010
NODE_ENV=development
AUTO_SCHEDULES_FILE=./auto-schedules.json

# Supabase per company (JSON array)
# company: franca | litoral | mogiana | imperatriz
# key can be anon or service role (recommended for backend).
SUPABASE_COMPANIES_JSON=[
  {"company":"franca","url":"https://xxxx.supabase.co","key":"YOUR_KEY"},
  {"company":"litoral","url":"https://xxxx.supabase.co","key":"YOUR_KEY"},
  {"company":"mogiana","url":"https://xxxx.supabase.co","key":"YOUR_KEY"},
  {"company":"imperatriz","url":"https://xxxx.supabase.co","key":"YOUR_KEY"}
]

# Evolution API
EVOLUTION_BASE_URL=http://212.85.19.210:3000
# Chaves por instância já vêm no código; use isto só para sobrescrever em produção:
# EVOLUTION_KEYS_JSON={"omnibot2":"...","vinicius":"...","douglas":"..."}
# Opcional: uma única key legada se nada mais existir
# EVOLUTION_API_KEY=

# Fine
FINE_PER_DAY=50

# PIX for message template (optional; can be overridden later)
PIX_BANK=PIX
PIX_HOLDER=NOVIXCRED
PIX_KEY=00000000000

# CORS
FRONTEND_ORIGIN=http://localhost:5173

